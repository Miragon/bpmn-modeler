{
  "private": true,
  "name": "@miragon/bpmn-modeler-standalone",
  "description": "Miragon BPMN Modeler — standalone Theia-based Electron desktop app",
  "productName": "Miragon BPMN Modeler",
  "version": "0.0.6",
  "main": "scripts/theia-electron-main.js",
  "license": "Apache-2.0",
  "author": "Miragon",
  "engines": {
    "node": ">=22"
  },
  "theia": {
    "target": "electron",
    "frontend": {
      "config": {
        "applicationName": "Miragon BPMN Modeler",
        "reloadOnReconnect": true,
        "defaultTheme": {
          "light": "miragon-light",
          "dark": "miragon-dark"
        },
        "preferences": {
          "files.enableTrash": false,
          "files.autoSave": "afterDelay",
          "files.autoSaveDelay": 1000,
          "security.workspace.trust.enabled": false
        },
        "electron": {
          "splashScreenOptions": {
            "content": "resources/splash.html",
            "width": 480,
            "height": 320,
            "minDuration": 1000,
            "maxDuration": 30000
          }
        }
      }
    },
    "backend": {
      "config": {
        "frontendConnectionTimeout": -1,
        "startupTimeout": -1,
        "resolveSystemPlugins": false,
        "configurationFolder": ".miragon-bpmn-modeler"
      }
    }
  },
  "dependencies": {
    "@miragon/bpmn-modeler-standalone-extension": "workspace:*",
    "@theia/core": "1.71.1",
    "@theia/editor": "1.71.1",
    "@theia/electron": "1.71.1",
    "@theia/filesystem": "1.71.1",
    "@theia/keymaps": "1.71.1",
    "@theia/messages": "1.71.1",
    "@theia/monaco": "1.71.1",
    "@theia/navigator": "1.71.1",
    "@theia/output": "1.71.1",
    "@theia/plugin-ext": "1.71.1",
    "@theia/plugin-ext-vscode": "1.71.1",
    "@theia/preferences": "1.71.1",
    "@theia/process": "1.71.1",
    "@theia/scm": "1.71.1",
    "@theia/scm-extra": "1.71.1",
    "@theia/terminal": "1.71.1",
    "@theia/variable-resolver": "1.71.1",
    "@theia/workspace": "1.71.1",
    "electron-updater": "6.8.3",
    "yauzl": "3.3.0"
  },
  "theiaPluginsDir": "plugins",
  "theiaPlugins": {
    "vscode.git": "https://open-vsx.org/api/vscode/git/1.95.3/file/vscode.git-1.95.3.vsix"
  },
  "devDependencies": {
    "@theia/cli": "1.71.1",
    "@theia/native-webpack-plugin": "1.71.1",
    "@vscode/vsce": "3.9.1",
    "electron": "42.0.1",
    "electron-builder": "26.8.1",
    "npm-run-all": "4.1.5",
    "rimraf": "6.1.3"
  },
  "scripts": {
    "bundle": "node scripts/bundle-extension.mjs",
    "clean": "theia clean && rimraf node_modules lib src-gen dist gen-webpack*.js",
    "clean:dist": "rimraf dist",
    "rebuild": "theia rebuild:electron --cacheRoot ../..",
    "build:extension": "corepack yarn workspace @miragon/bpmn-modeler-standalone-extension build",
    "build": "npm-run-all -s build:extension build:theia",
    "build:theia": "theia build --app-target=\"electron\" --mode development",
    "build:prod": "npm-run-all -s build:extension build:prod:theia",
    "build:prod:theia": "theia build --app-target=\"electron\"",
    "build:repo": "corepack yarn --cwd ../.. build",
    "package-plugin": "node scripts/package-plugin.mjs",
    "download:plugins": "theia download:plugins",
    "prepare-plugin": "npm-run-all -s download:plugins package-plugin bundle",
    "dev": "npm-run-all -s build:repo prepare-plugin build start",
    "dev:fast": "npm-run-all -s build start",
    "start": "electron scripts/theia-electron-main.js",
    "start:debug": "yarn start --log-level=debug",
    "package": "yarn clean:dist && yarn download:plugins && yarn rebuild && yarn build:prod && electron-builder -c.mac.identity=null -c.mac.notarize=false -c.mac.hardenedRuntime=false --publish never --mac dmg",
    "package:signed": "yarn clean:dist && yarn download:plugins && yarn rebuild && yarn build:prod && electron-builder --publish never --mac dmg",
    "package:release": "yarn clean:dist && yarn download:plugins && yarn rebuild && yarn build:prod && electron-builder --publish never --mac dmg"
  }
}
