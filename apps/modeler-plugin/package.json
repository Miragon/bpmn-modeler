{
    "name": "vs-code-bpmn-modeler",
    "scripts": {
        "build": "webpack --mode production",
        "dev": "webpack --mode development --watch"
    },
    "displayName": "Camunda Modeler by Miragon",
    "description": "Create and edit BPMN 2.0 and DMN Diagrams for Camunda 7 and Camunda 8 with VS Code.",
    "license": "SEE LICENSE IN LICENSE",
    "version": "0.9.2",
    "publisher": "miragon-gmbh",
    "homepage": "https://www.miragon.io/",
    "galleryBanner": {
        "color": "#F0F8FF",
        "theme": "light"
    },
    "badges": [
        {
            "url": "https://img.shields.io/badge/Follow-@miragon__io-1DA1F2?style=social&logo=twitter&logoColor=1DA1F2",
            "href": "https://twitter.com/miragon_io",
            "description": "Our Twitter profile."
        },
        {
            "url": "https://img.shields.io/badge/Follow-miragon-blue?style=social&logo=linkedin&logoColor=blue&url=https://www.linkedin.com/company/miragon-io",
            "href": "https://www.linkedin.com/company/miragon-io",
            "description": "Our LinkedIn profile."
        }
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/Miragon/bpmn-vscode-modeler.git"
    },
    "bugs": {
        "url": "https://github.com/Miragon/bpmn-vscode-modeler/issues"
    },
    "engines": {
        "vscode": "^1.76.0"
    },
    "icon": "assets/miragon-logo.png",
    "categories": [
        "Visualization",
        "Other"
    ],
    "keywords": [
        "BPMN",
        "DMN",
        "bpmn.io",
        "Modeler",
        "Camunda",
        "Camunda Modeler",
        "Automation",
        "business process",
        "decision table"
    ],
    "main": "main.js",
    "contributes": {
        "customEditors": [
            {
                "id": "bpmn-modeler.bpmn",
                "viewType": "bpmn-modeler.bpmn",
                "displayName": "BPMN Modeler",
                "selector": [
                    {
                        "filenamePattern": "*.bpmn"
                    }
                ],
                "priority": "default"
            },
            {
                "id": "bpmn-modeler.dmn",
                "viewType": "bpmn-modeler.dmn",
                "displayName": "DMN Modeler",
                "selector": [
                    {
                        "filenamePattern": "*.dmn"
                    }
                ],
                "priority": "default"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "bpmn-modeler-deploy",
                    "title": "Deploy Diagram",
                    "icon": "$(rocket)"
                }
            ]
        },
        "views": {
            "bpmn-modeler-deploy": [
                {
                    "type": "webview",
                    "id": "bpmn-modeler.deploymentView",
                    "name": "Deploy Diagram",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                }
            ]
        },
        "commands": [
            {
                "command": "bpmn-modeler.toggleTextEditor",
                "title": "BPMN Modeler: Toggle Standard Text Editor",
                "icon": "$(notebook-mimetype)"
            },
            {
                "command": "bpmn-modeler.openLoggingConsole",
                "title": "BPMN Modeler: Display Logging Information",
                "icon": "$(callstack-view-session)"
            },
            {
                "command": "bpmn-modeler.copyDiagramAsSvg",
                "title": "BPMN Modeler: Copy Diagram as SVG"
            },
            {
                "command": "bpmn-modeler.saveDiagramAsSvgCommand",
                "title": "BPMN Modeler: Save Diagram as SVG"
            },
            {
                "command": "bpmn-modeler.deployDiagram",
                "title": "BPMN Modeler: Deploy Diagram",
                "icon": "$(rocket)"
            },
            {
                "command": "bpmn-modeler.changeEngineVersion",
                "title": "BPMN Modeler: Change Engine Version"
            },
            {
                "command": "bpmn-modeler.migrateAllDiagrams",
                "title": "BPMN Modeler: Migrate All BPMN Diagrams"
            },
            {
                "command": "bpmn-modeler.changeLanguage",
                "title": "BPMN Modeler: Change Modeler Language"
            },
            {
                "command": "bpmn-modeler.selectForCompare",
                "title": "BPMN Modeler: Select for Compare"
            },
            {
                "command": "bpmn-modeler.compareWithSelected",
                "title": "BPMN Modeler: Compare with Selected"
            },
            {
                "command": "bpmn-modeler.compareSelected",
                "title": "BPMN Modeler: Compare Selected"
            }
        ],
        "keybindings": [
            {
                "command": "bpmn-modeler.toggleTextEditor",
                "key": "ctrl+shift+e",
                "when": "bpmn-modeler.openCustomEditors > 0"
            }
        ],
        "menus": {
            "commandPalette": [
                {
                    "command": "bpmn-modeler.toggleTextEditor",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.openLoggingConsole",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.copyDiagramAsSvg",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.saveDiagramAsSvgCommand",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.deployDiagram",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.changeEngineVersion",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.migrateAllDiagrams",
                    "when": "workspaceFolderCount > 0"
                },
                {
                    "command": "bpmn-modeler.changeLanguage",
                    "when": "bpmn-modeler.openCustomEditors > 0"
                },
                {
                    "command": "bpmn-modeler.selectForCompare",
                    "when": "false"
                },
                {
                    "command": "bpmn-modeler.compareWithSelected",
                    "when": "false"
                },
                {
                    "command": "bpmn-modeler.compareSelected",
                    "when": "false"
                }
            ],
            "explorer/context": [
                {
                    "command": "bpmn-modeler.selectForCompare",
                    "group": "3_compare",
                    "when": "resourceExtname == .bpmn && !listMultiSelection"
                },
                {
                    "command": "bpmn-modeler.compareWithSelected",
                    "group": "3_compare",
                    "when": "resourceExtname == .bpmn && bpmn-modeler.compareSelectionActive && !listMultiSelection"
                },
                {
                    "command": "bpmn-modeler.compareSelected",
                    "group": "3_compare",
                    "when": "resourceExtname == .bpmn && listDoubleSelection"
                }
            ],
            "editor/title": [
                {
                    "command": "bpmn-modeler.toggleTextEditor",
                    "group": "navigation",
                    "when": "activeWebviewPanelId == 'bpmn-modeler.bpmn' || activeWebviewPanelId == 'bpmn-modeler.dmn'"
                },
                {
                    "command": "bpmn-modeler.deployDiagram",
                    "group": "navigation",
                    "when": "activeWebviewPanelId == 'bpmn-modeler.bpmn'"
                }
            ]
        },
        "configuration": {
            "title": "BPMN Modeler",
            "properties": {
                "miragon.bpmnModeler.alignToOrigin": {
                    "type": "boolean",
                    "default": false,
                    "markdownDescription": "Align the diagram to the origin when opening a new diagram. Click [here](https://github.com/bpmn-io/align-to-origin) to see the behaviour when enabled."
                },
                "miragon.bpmnModeler.configFolder": {
                    "type": "string",
                    "default": ".camunda",
                    "markdownDescription": "Name of the config folder searched at each directory level from the BPMN file up to the workspace root. **Element templates must be placed under `<config>/element-templates/`** (e.g. `.camunda/element-templates/my-template.json`)."
                },
                "miragon.bpmnModeler.c8ApiVersion": {
                    "type": "string",
                    "default": "v2",
                    "markdownDescription": "REST API version prefix for Camunda 8 endpoints (e.g. `v2`). Change this if your Camunda 8 cluster uses a different API version."
                },
                "miragon.bpmnModeler.showTransactionBoundaries": {
                    "type": "boolean",
                    "default": true,
                    "markdownDescription": "Show transaction boundaries in the BPMN diagram (Camunda 7 only). Click [here](https://docs.camunda.io/docs/8.7/components/best-practices/development/understanding-transaction-handling-c7/) to learn more."
                },
                "miragon.bpmnModeler.colorTheme": {
                    "type": "string",
                    "default": "automatic",
                    "enum": [
                        "automatic",
                        "light"
                    ],
                    "enumItemLabels": [
                        "Automatic (follow VS Code theme)",
                        "Light"
                    ],
                    "markdownDescription": "Controls the color theme of the BPMN modeler canvas. `automatic` follows the active VS Code theme; `light` always uses the default bpmn-js light theme."
                },
                "miragon.bpmnModeler.favouriteBpmnElements": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "bpmn:ServiceTask",
                        "bpmn:UserTask",
                        "bpmn:CallActivity",
                        "bpmn:ExclusiveGateway"
                    ],
                    "maxItems": 6,
                    "markdownDescription": "BPMN element types to pin at the top of the append menu palette (max 6). Use BPMN type names like `bpmn:ServiceTask`, `bpmn:UserTask`, `bpmn:CallActivity`, `bpmn:ExclusiveGateway`."
                },
                "miragon.bpmnModeler.language": {
                    "type": "string",
                    "default": "en",
                    "enum": [
                        "de",
                        "en",
                        "es",
                        "fr",
                        "nl-nl",
                        "pt-br",
                        "ru",
                        "zh-Hans",
                        "zh-Hant"
                    ],
                    "enumItemLabels": [
                        "Deutsch",
                        "English",
                        "Español",
                        "Français",
                        "Nederlands",
                        "Português (Brasil)",
                        "Русский",
                        "简体中文",
                        "繁体中文"
                    ],
                    "markdownDescription": "UI language for the BPMN/DMN modeler (palette, context pad, properties panel)."
                }
            }
        }
    }
}
