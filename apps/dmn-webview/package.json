        "@bpmn-modeler/shared": "workspace:*",
        "camunda-dmn-moddle": "1.3.1",
        "diagram-js": "15.12.0",
        "dmn-js": "17.7.0",
        "dmn-js-properties-panel": "3.11.0",
        "min-dash": "5.0.0",
        "tslib": "2.8.1"
    },
    "devDependencies": {
        "@types/vscode-webview": "1.57.5",
        "typescript": "5.9.3",
        "vite": "7.3.2",
        "vite-plugin-static-copy": "3.3.0",
        "vite-tsconfig-paths": "6.1.1"
    }
}
