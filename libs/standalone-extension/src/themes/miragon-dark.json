        "titleBar.border": "#1f1f1f",

        "menubar.selectionBackground": "#1f1f1f",
        "menubar.selectionForeground": "#00E676",

        "activityBar.background": "#333333",
        "activityBar.foreground": "#e6e6e6",
        "activityBar.inactiveForeground": "#7a7a7a",
        "activityBar.border": "#1f1f1f",
        "activityBar.activeBorder": "#00E676",
        "activityBar.activeBackground": "#3c3c3c",
        "activityBarBadge.background": "#00E676",
        "activityBarBadge.foreground": "#0a0a0a",

        "sideBar.background": "#252526",
        "sideBar.foreground": "#e6e6e6",
        "sideBar.border": "#1f1f1f",
        "sideBarTitle.foreground": "#ffffff",
        "sideBarSectionHeader.background": "#252526",
        "sideBarSectionHeader.foreground": "#ffffff",
        "sideBarSectionHeader.border": "#1f1f1f",

        "list.activeSelectionBackground": "#1f1f1f",
        "list.activeSelectionForeground": "#00E676",
        "list.inactiveSelectionBackground": "#1a1a1a",
        "list.inactiveSelectionForeground": "#ffffff",
        "list.hoverBackground": "#1a1a1a",
        "list.focusBackground": "#1f1f1f",
        "list.focusForeground": "#ffffff",
        "list.highlightForeground": "#00E676",

        "editor.background": "#1e1e1e",
        "editor.foreground": "#e6e6e6",
        "editor.lineHighlightBackground": "#262626",
        "editor.selectionBackground": "#00E67633",
        "editor.findMatchBackground": "#00E67666",
        "editor.findMatchHighlightBackground": "#00E67633",
        "editorLineNumber.foreground": "#5a5a5a",
        "editorLineNumber.activeForeground": "#00E676",
        "editorCursor.foreground": "#00E676",
        "editorWidget.background": "#252526",
        "editorWidget.border": "#1f1f1f",
        "editorGroupHeader.tabsBackground": "#252526",
        "editorGroupHeader.tabsBorder": "#1f1f1f",
        "editorGroup.border": "#1f1f1f",

        "tab.activeBackground": "#1e1e1e",
        "tab.activeForeground": "#ffffff",
        "tab.activeBorderTop": "#00E676",
        "tab.inactiveBackground": "#2d2d2d",
        "tab.inactiveForeground": "#9e9e9e",
        "tab.border": "#1f1f1f",
        "tab.hoverBackground": "#2a2d2e",

        "panel.background": "#1e1e1e",
        "panel.border": "#1f1f1f",
        "panelTitle.activeBorder": "#00E676",
        "panelTitle.activeForeground": "#ffffff",
        "panelTitle.inactiveForeground": "#9e9e9e",

        "button.background": "#00E676",
        "button.foreground": "#0a0a0a",
        "button.hoverBackground": "#00E676",
        "button.secondaryBackground": "#1f1f1f",
        "button.secondaryForeground": "#ffffff",
        "button.secondaryHoverBackground": "#2a2a2a",

        "input.background": "#1a1a1a",
        "input.foreground": "#ffffff",
        "input.border": "#1f1f1f",
        "input.placeholderForeground": "#7a7a7a",
        "inputOption.activeBackground": "#00E67633",
        "inputOption.activeBorder": "#00E676",

        "dropdown.background": "#1a1a1a",
        "dropdown.foreground": "#ffffff",
        "dropdown.border": "#1f1f1f",

        "badge.background": "#00E676",
        "badge.foreground": "#0a0a0a",

        "progressBar.background": "#00E676",

        "scrollbarSlider.background": "#2a2a2a80",
        "scrollbarSlider.hoverBackground": "#3a3a3a",
        "scrollbarSlider.activeBackground": "#00E676",

        "notificationCenterHeader.background": "#252526",
        "notifications.background": "#252526",
        "notifications.foreground": "#ffffff",
        "notifications.border": "#1f1f1f",

        "terminal.background": "#1e1e1e",
        "terminal.foreground": "#e6e6e6",
        "terminalCursor.foreground": "#00E676",

        "menu.background": "#252526",
        "menu.foreground": "#e6e6e6",
        "menu.selectionBackground": "#1f1f1f",
        "menu.selectionForeground": "#00E676",
        "menu.separatorBackground": "#1f1f1f",

        "peekView.border": "#00E676",
        "peekViewTitle.background": "#252526",
        "peekViewEditor.background": "#1e1e1e",
        "peekViewResult.background": "#252526"
    },
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#6a6a6a", "fontStyle": "italic" }
        },
        {
            "scope": ["string", "constant.other.symbol"],
            "settings": { "foreground": "#00E676" }
        },
        {
            "scope": ["constant.numeric", "constant.language"],
            "settings": { "foreground": "#00E676" }
        },
        {
            "scope": ["keyword", "storage", "storage.type"],
            "settings": { "foreground": "#00E676" }
        },
        {
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#7fdfff" }
        },
        {
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": { "foreground": "#ffd479" }
        },
        {
            "scope": ["variable", "variable.parameter"],
            "settings": { "foreground": "#e6e6e6" }
        }
    ]
}
