{
    "name": "Miragon Light",
    "type": "light",
    "colors": {
        "focusBorder": "#00b85f",
        "foreground": "#1e1e1e",
        "descriptionForeground": "#5a5a5a",
        "errorForeground": "#c62828",

        "statusBar.background": "#00e676",
        "statusBar.foreground": "#0a0a0a",
        "statusBar.border": "#00e676",
        "statusBar.noFolderBackground": "#00e676",
        "statusBar.noFolderForeground": "#0a0a0a",
        "statusBar.debuggingBackground": "#00b85f",
        "statusBar.debuggingForeground": "#ffffff",
        "statusBarItem.hoverBackground": "#00b85f",
        "statusBarItem.remoteBackground": "#0a0a0a",
        "statusBarItem.remoteForeground": "#00e676",
        "statusBarItem.prominentBackground": "#0a0a0a",
        "statusBarItem.prominentHoverBackground": "#1f1f1f",

        "titleBar.activeBackground": "#ffffff",
        "titleBar.activeForeground": "#0a0a0a",
        "titleBar.inactiveBackground": "#f5f5f5",
        "titleBar.inactiveForeground": "#5a5a5a",
        "titleBar.border": "#e0e0e0",

        "menubar.selectionBackground": "#e8e8e8",
        "menubar.selectionForeground": "#00b85f",

        "activityBar.background": "#ffffff",
        "activityBar.foreground": "#0a0a0a",
        "activityBar.inactiveForeground": "#9e9e9e",
        "activityBar.border": "#e0e0e0",
        "activityBar.activeBorder": "#00b85f",
        "activityBar.activeBackground": "#f0f0f0",
        "activityBarBadge.background": "#00b85f",
        "activityBarBadge.foreground": "#ffffff",

        "sideBar.background": "#f5f5f5",
        "sideBar.foreground": "#1e1e1e",
        "sideBar.border": "#e0e0e0",
        "sideBarTitle.foreground": "#0a0a0a",
        "sideBarSectionHeader.background": "#eeeeee",
        "sideBarSectionHeader.foreground": "#0a0a0a",
        "sideBarSectionHeader.border": "#e0e0e0",

        "list.activeSelectionBackground": "#e0e0e0",
        "list.activeSelectionForeground": "#00b85f",
        "list.inactiveSelectionBackground": "#ececec",
        "list.inactiveSelectionForeground": "#0a0a0a",
        "list.hoverBackground": "#ececec",
        "list.focusBackground": "#e0e0e0",
        "list.focusForeground": "#0a0a0a",
        "list.highlightForeground": "#00b85f",

        "editor.background": "#ffffff",
        "editor.foreground": "#1e1e1e",
        "editor.lineHighlightBackground": "#f0f0f0",
        "editor.selectionBackground": "#00b85f33",
        "editor.findMatchBackground": "#00b85f66",
        "editor.findMatchHighlightBackground": "#00b85f33",
        "editorLineNumber.foreground": "#bdbdbd",
        "editorLineNumber.activeForeground": "#00b85f",
        "editorCursor.foreground": "#00b85f",
        "editorWidget.background": "#f5f5f5",
        "editorWidget.border": "#e0e0e0",
        "editorGroupHeader.tabsBackground": "#eeeeee",
        "editorGroupHeader.tabsBorder": "#e0e0e0",
        "editorGroup.border": "#e0e0e0",

        "tab.activeBackground": "#ffffff",
        "tab.activeForeground": "#0a0a0a",
        "tab.activeBorderTop": "#00b85f",
        "tab.inactiveBackground": "#eeeeee",
        "tab.inactiveForeground": "#5a5a5a",
        "tab.border": "#e0e0e0",
        "tab.hoverBackground": "#f5f5f5",

        "panel.background": "#f5f5f5",
        "panel.border": "#e0e0e0",
        "panelTitle.activeBorder": "#00b85f",
        "panelTitle.activeForeground": "#0a0a0a",
        "panelTitle.inactiveForeground": "#5a5a5a",

        "button.background": "#00b85f",
        "button.foreground": "#ffffff",
        "button.hoverBackground": "#00a052",
        "button.secondaryBackground": "#e0e0e0",
        "button.secondaryForeground": "#0a0a0a",
        "button.secondaryHoverBackground": "#d0d0d0",

        "input.background": "#ffffff",
        "input.foreground": "#0a0a0a",
        "input.border": "#d0d0d0",
        "input.placeholderForeground": "#9e9e9e",
        "inputOption.activeBackground": "#00b85f33",
        "inputOption.activeBorder": "#00b85f",

        "dropdown.background": "#ffffff",
        "dropdown.foreground": "#0a0a0a",
        "dropdown.border": "#d0d0d0",

        "badge.background": "#00b85f",
        "badge.foreground": "#ffffff",

        "progressBar.background": "#00b85f",

        "scrollbarSlider.background": "#bdbdbd80",
        "scrollbarSlider.hoverBackground": "#9e9e9e",
        "scrollbarSlider.activeBackground": "#00b85f",

        "notificationCenterHeader.background": "#eeeeee",
        "notifications.background": "#ffffff",
        "notifications.foreground": "#0a0a0a",
        "notifications.border": "#e0e0e0",

        "terminal.background": "#ffffff",
        "terminal.foreground": "#1e1e1e",
        "terminalCursor.foreground": "#00b85f",

        "menu.background": "#ffffff",
        "menu.foreground": "#1e1e1e",
        "menu.selectionBackground": "#e8e8e8",
        "menu.selectionForeground": "#00b85f",
        "menu.separatorBackground": "#e0e0e0",

        "peekView.border": "#00b85f",
        "peekViewTitle.background": "#eeeeee",
        "peekViewEditor.background": "#ffffff",
        "peekViewResult.background": "#f5f5f5"
    },
    "tokenColors": [
        {
            "scope": ["comment", "punctuation.definition.comment"],
            "settings": { "foreground": "#7a7a7a", "fontStyle": "italic" }
        },
        {
            "scope": ["string", "constant.other.symbol"],
            "settings": { "foreground": "#0d8043" }
        },
        {
            "scope": ["constant.numeric", "constant.language"],
            "settings": { "foreground": "#00b85f" }
        },
        {
            "scope": ["keyword", "storage", "storage.type"],
            "settings": { "foreground": "#00875a" }
        },
        {
            "scope": ["entity.name.function", "support.function"],
            "settings": { "foreground": "#1565c0" }
        },
        {
            "scope": ["entity.name.type", "entity.name.class", "support.type", "support.class"],
            "settings": { "foreground": "#a6630e" }
        },
        {
            "scope": ["variable", "variable.parameter"],
            "settings": { "foreground": "#1e1e1e" }
        }
    ]
}
