{
  "private": true,
  "name": "@miragon/bpmn-modeler-standalone-extension",
  "version": "0.0.5",
  "description": "Theia frontend extension contributing Miragon themes and view overrides for @miragon/bpmn-modeler-standalone.",
  "license": "Apache-2.0",
  "main": "lib/frontend-module.js",
  "files": [
    "lib"
  ],
  "theiaExtensions": [
    {
      "frontend": "lib/frontend-module"
    }
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && node scripts/copy-assets.mjs",
    "watch": "tsc -p tsconfig.json --watch",
    "clean": "rimraf lib"
  },
  "dependencies": {
    "@theia/core": "1.70.2",
    "@theia/monaco": "1.70.2"
  },
  "devDependencies": {
    "rimraf": "6.1.3",
    "typescript": "6.0.3"
  }
}
