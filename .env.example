# Copy this file to `.env` in the repo root to activate local overrides:
#
#     cp .env.example .env
#
# Variables are read by `apps/bpmn-iq-plugin/webpack.config.js` via `dotenv`
# and baked into the extension bundle through Webpack's DefinePlugin. This
# applies to both `yarn build` and `yarn watch` (the F5 debug session) —
# webpack picks up `.env` whenever it (re)loads the config. After editing
# `.env` during a running watch task, restart it to re-bake values.
#
# `.env` is gitignored. Leave variables empty (or unset) in OSS clones —
# the affected features detect the empty string and stay hidden/disabled.

# URL of the Miragon Cloud bpmn-iq daemon. When set, the bpmn-iq status-bar
# menu shows a "Switch to Miragon Cloud" entry. Enterprise-only; leave empty
# in OSS builds. The user-level VS Code setting `miragon.bpmnIq.cloudDaemonUrl`
# overrides this baked value at runtime.
MIRAGON_CLOUD_DAEMON_URL=
