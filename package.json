{
    "name": "bpmn-vscode-modeler",
    "version": "0.6.2",
    "license": "Apache-2.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "libs/*"
    ],
    "scripts": {
        "build": "npm-run-all -s build:libs -p build:bpmn-webview build:dmn-webview build:deployment-webview -s build:plugin",
        "build:libs": "npm-run-all build:lib:shared",
        "build:lib:shared": "corepack yarn workspace @bpmn-modeler/shared build",
        "build:bpmn-webview": "corepack yarn workspace bpmn-webview build",
        "build:dmn-webview": "corepack yarn workspace dmn-webview build",
        "build:deployment-webview": "corepack yarn workspace deployment-webview build",
        "build:plugin": "corepack yarn workspace vs-code-bpmn-modeler build",
        "dev:deployment-webview": "corepack yarn workspace deployment-webview dev",
        "dev": "npm-run-all -s build:libs build:bpmn-webview build:dmn-webview build:deployment-webview -p dev:libs dev:bpmn-webview dev:dmn-webview dev:deployment-webview dev:plugin",
        "dev:libs": "npm-run-all dev:lib:shared",
        "dev:lib:shared": "corepack yarn workspace @bpmn-modeler/shared dev",
        "dev:bpmn-webview": "corepack yarn workspace bpmn-webview dev",
        "dev:dmn-webview": "corepack yarn workspace dmn-webview dev",
        "dev:plugin": "corepack yarn workspace vs-code-bpmn-modeler dev",
        "serve:bpmn-webview": "corepack yarn workspace bpmn-webview serve",
        "serve:dmn-webview": "corepack yarn workspace dmn-webview serve",
        "serve:deployment-webview": "corepack yarn workspace deployment-webview serve",
        "test": "jest --coverage",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.10.0",
        "@types/jest": "^30.0.0",
        "@types/lodash": "^4.17.24",
        "@types/node": "20.x",
        "@types/uuid": "^11.0.0",
        "@types/vscode": "^1.76.0",
        "@types/vscode-webview": "^1.57.5",
        "@typescript-eslint/eslint-plugin": "^8.57.2",
        "@typescript-eslint/parser": "^8.57.2",
        "@vitest/coverage-v8": "4.1.1",
        "@vitest/ui": "4.1.1",
        "copy-webpack-plugin": "^14.0.0",
        "eslint": "^10.1.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.3.0",
        "jest-environment-node": "^30.3.0",
        "npm-run-all": "^4.1.5",
        "prettier": "^3.8.1",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths-webpack-plugin": "^4.2.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.57.2",
        "vite": "8.0.2",
        "vite-plugin-static-copy": "3.3.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "4.1.1",
        "webpack": "^5.98.0",
        "webpack-cli": "^7.0.2"
    },
    "dependencies": {
        "@bpmn-io/element-template-chooser": "^2.1.0",
        "@bpmn-io/form-js": "1.21.2",
        "@bpmn-io/properties-panel": "3.40.4",
        "bpmn-js": "^18.13.2",
        "bpmn-js-create-append-anything": "^1.2.0",
        "bpmn-js-native-copy-paste": "^0.3.0",
        "bpmn-js-properties-panel": "^5.53.0",
        "bpmn-js-token-simulation": "^0.39.3",
        "camunda-bpmn-js": "^5.24.2",
        "camunda-bpmn-js-behaviors": "^1.14.1",
        "camunda-bpmn-moddle": "^7.0.1",
        "camunda-dmn-moddle": "^1.3.1",
        "camunda-transaction-boundaries": "^1.1.2",
        "diagram-js": "^15.10.0",
        "dmn-js": "^17.7.0",
        "dmn-js-properties-panel": "^3.10.0",
        "lodash": "4.17.23",
        "min-dash": "^5.0.0",
        "tslib": "^2.8.1",
        "uuid": "^13.0.0",
        "zeebe-bpmn-moddle": "^1.12.0"
    },
    "resolutions": {
        "preact": "10.28.4"
    },
    "packageManager": "yarn@4.13.0"
}
