{
    "name": "bpmn-modeler",
    "version": "0.6.2",
    "license": "Apache-2.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "libs/*",
        "docs"
    ],
    "scripts": {
        "build": "npm-run-all -s build:libs -p build:bpmn-webview build:dmn-webview build:deployment-webview -s build:plugin",
        "build:libs": "npm-run-all build:lib:shared",
        "build:lib:shared": "corepack yarn workspace @bpmn-modeler/shared build",
        "build:bpmn-webview": "corepack yarn workspace bpmn-webview build",
        "build:dmn-webview": "corepack yarn workspace dmn-webview build",
        "build:deployment-webview": "corepack yarn workspace deployment-webview build",
        "build:plugin": "corepack yarn workspace vs-code-bpmn-modeler build",
        "dev:libs": "npm-run-all dev:lib:shared",
        "dev:lib:shared": "corepack yarn workspace @bpmn-modeler/shared dev",
        "dev:bpmn-webview": "corepack yarn workspace bpmn-webview dev",
        "dev:dmn-webview": "corepack yarn workspace dmn-webview dev",
        "dev:deployment-webview": "corepack yarn workspace deployment-webview dev",
        "dev:plugin": "corepack yarn workspace vs-code-bpmn-modeler dev",
        "watch": "npm-run-all -s build:libs build:bpmn-webview build:dmn-webview build:deployment-webview -p dev:libs watch:bpmn-webview watch:dmn-webview watch:deployment-webview dev:plugin",
        "watch:bpmn-webview": "corepack yarn workspace bpmn-webview watch",
        "watch:dmn-webview": "corepack yarn workspace dmn-webview watch",
        "watch:deployment-webview": "corepack yarn workspace deployment-webview watch",
        "docs:dev": "corepack yarn workspace docs dev",
        "docs:build": "corepack yarn workspace docs build",
        "docs:preview": "corepack yarn workspace docs preview",
        "test": "corepack yarn workspace vs-code-bpmn-modeler test",
        "lint": "eslint ."
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@stylistic/eslint-plugin": "5.10.0",
        "@typescript-eslint/eslint-plugin": "8.58.2",
        "@typescript-eslint/parser": "8.58.2",
        "eslint": "10.2.0",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "npm-run-all": "4.1.5",
        "prettier": "3.8.3",
        "typescript": "5.9.3",
        "typescript-eslint": "8.58.2"
    },
    "resolutions": {
        "preact": "10.28.4",
        "webpack-cli": "4.10.0"
    },
    "packageManager": "yarn@4.14.1"
}
